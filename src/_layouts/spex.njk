<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <title>{{ tabTitle or title }} - Bajbeln</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/assets/images/logga.png">
  <link rel="manifest" href="/manifest.json">
  <script src="/scripts/songIndexCache.js" defer></script>
  <script src="/scripts/searchscript.js" defer></script>
  <script src="/scripts/pagescript.js" defer></script>
  <script src="/scripts/settings.js" defer></script>
  {% if color or accentColor or accentBorderColor or darkColor %}<style>
    {% if color %}body { background-color: {{ color }}; }{% endif %}
    {% if accentColor %}.collapsible, .song-body { background-color: {{ accentColor }}; }{% endif %}
    {% if accentBorderColor %}.collapsible, .song-body { border-color: {{ accentBorderColor }}; }{% endif %}
    {% if accentColor %}body.dark-mode .collapsible, body.dark-mode .song-body { background-color: {{ darkAccentColor or '#2d3a5e' }}; border-color: {{ darkAccentBorderColor or darkAccentColor or '#2d3a5e' }}; }{% endif %}
    {% if darkColor %}body.dark-mode { background-color: {{ darkColor }}; }{% endif %}
  </style>{% endif %}
</head>
<body>
  <h2>{{ title }}</h2>
  <button class="btn-copy" onclick="copyLink()" aria-label="Kopiera länk till sida">Kopiera länk</button>
  <button class="btn-toggle-all" id="toggleAllBtn" onclick="toggleAll()" aria-label="Expandera/kollapsa alla sånger">
    <svg class="icon-expand" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
      <polyline points="3,4 10,10 17,4" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="3,11 10,17 17,11" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
    <svg class="icon-collapse" width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" style="display:none">
      <polyline points="3,10 10,4 17,10" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <polyline points="3,17 10,11 17,17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </button>
  <br><br>

  {% if songs %}
    {% set pageSongs = collections.songs | songsFromList(songs) %}
    {% for song in pageSongs %}{{ song | renderSong | safe }}{% endfor %}
  {% elif uppsattning %}
    {% set _prefix = page.url | replace("/", "") %}
    {% for u in uppsattning %}
      {% set _sectionId = u.id | replace(_prefix ~ "-", "") | replace("-", "_") %}
      <br>
      <div class="uppsattning-header">
        <h2 class="uppsattning-heading" id="{{ _sectionId }}">{{ u.label }}</h2>
        <button class="btn-production-link" onclick="copyUppLink(this, '{{ _sectionId }}')" aria-label="Kopiera länk till {{ u.label }}"><img src="/assets/images/song-link-button.png" class="song-link-icon" alt=""></button>
      </div>
      <br>
      {% set groupSongs = collections.songs | songsForSpex(u.id) %}
      {% for song in groupSongs %}{{ song | renderSong | safe }}{% endfor %}
      <br>
    {% endfor %}
  {% elif spex %}
    {% set pageSongs = collections.songs | songsForSpex(spex) %}
    {% for song in pageSongs %}{{ song | renderSong | safe }}{% endfor %}
  {% else %}
    {{ content | safe }}
  {% endif %}

  <script>
    // Collapsible song sections — find .content inside the same .song-block
    var coll = document.getElementsByClassName("collapsible");
    for (var i = 0; i < coll.length; i++) {
      coll[i].addEventListener("click", function () {
        this.classList.toggle("active");
        var block = this.closest(".song-block");
        var contentDiv = block ? block.querySelector(".song-body") : this.nextElementSibling;
        if (contentDiv.style.maxHeight) {
          contentDiv.style.maxHeight = null;
        } else {
          contentDiv.style.maxHeight = contentDiv.scrollHeight + "px";
        }
        updateToggleBtn();
      });
    }

    if (coll.length === 0) {
      var tBtn = document.getElementById("toggleAllBtn");
      if (tBtn) tBtn.style.display = "none";
    }

    function updateToggleBtn() {
      var btn = document.getElementById("toggleAllBtn");
      if (!btn) return;
      var anyOpen = Array.from(document.querySelectorAll(".song-block .song-body")).some(function (c) {
        return !!c.style.maxHeight;
      });
      btn.querySelector(".icon-expand").style.display = anyOpen ? "none" : "";
      btn.querySelector(".icon-collapse").style.display = anyOpen ? "" : "none";
    }

    function toggleAll() {
      var blocks = document.querySelectorAll(".song-block");
      var anyOpen = Array.from(blocks).some(function (block) {
        var c = block.querySelector(".song-body");
        return c && !!c.style.maxHeight;
      });
      blocks.forEach(function (block) {
        var contentDiv = block.querySelector(".song-body");
        var btn = block.querySelector(".collapsible");
        if (!contentDiv) return;
        if (anyOpen && contentDiv.style.maxHeight) {
          contentDiv.style.maxHeight = null;
          if (btn) btn.classList.remove("active");
        } else if (!anyOpen && !contentDiv.style.maxHeight) {
          contentDiv.style.maxHeight = contentDiv.scrollHeight + "px";
          if (btn) btn.classList.add("active");
        }
      });
      updateToggleBtn();
    }

    // Copy a direct anchor link to an uppsättning section
    function copyUppLink(btn, id) {
      var url = location.href.split("#")[0] + "#" + id;
      var img = btn.querySelector("img");
      function feedback() {
        if (img) {
          img.src = "/assets/images/song-link-feedback.png";
          setTimeout(function () { img.src = "/assets/images/song-link-button.png"; }, 1500);
        }
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(feedback).catch(function () { fallbackCopy(url); feedback(); });
      } else {
        fallbackCopy(url); feedback();
      }
    }

    // Copy a direct anchor link to a specific song
    function copySongLink(id) {
      var url = location.href.split("#")[0] + "#" + id;
      var songBtn = document.getElementById(id);
      var linkBtn = songBtn ? songBtn.nextElementSibling : null;
      var img = linkBtn ? linkBtn.querySelector("img") : null;

      function feedback() {
        if (img) {
          img.src = "/assets/images/song-link-feedback.png";
          setTimeout(function () { img.src = "/assets/images/song-link-button.png"; }, 1500);
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(feedback).catch(function () {
          fallbackCopy(url); feedback();
        });
      } else {
        fallbackCopy(url); feedback();
      }
    }

    function fallbackCopy(text) {
      var ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch (e) {}
      document.body.removeChild(ta);
    }

    // Open and scroll to a song or production section when the page loads with a hash
    document.addEventListener("DOMContentLoaded", function () {
      var hash = location.hash;
      if (hash && hash.length > 1) {
        var el = document.getElementById(hash.slice(1));
        if (!el) return;
        setTimeout(function () {
          el.scrollIntoView({ behavior: "smooth", block: "start" });
          if (el.classList.contains("collapsible")) {
            el.style.backgroundColor = "#ffd54f";
            setTimeout(function () { el.style.backgroundColor = ""; }, 2000);
            el.click();
          }
          updateToggleBtn();
        }, 100);
      }
    });
  </script>
</body>

<!-- Footer -->
<script src="/scripts/footer.js" defer></script>
<div id="footer-container"></div>

</html>
