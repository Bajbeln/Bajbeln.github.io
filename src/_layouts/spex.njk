<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <title>{{ tabTitle or title }} - Bajbeln</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/assets/images/logga.png">
  <link rel="manifest" href="/manifest.json">
  <script src="/scripts/songIndexCache.js" defer></script>
  <script src="/scripts/searchscript.js" defer></script>
  <script src="/scripts/pagescript.js" defer></script>
  <script src="/scripts/settings.js" defer></script>
  {% if color or accentColor or accentBorderColor or darkColor %}<style>
    {% if color %}body { background-color: {{ color }}; }{% endif %}
    {% if accentColor %}.collapsible, .content { background-color: {{ accentColor }}; }{% endif %}
    {% if accentBorderColor %}.collapsible, .content { border-color: {{ accentBorderColor }}; }{% endif %}
    {% if accentColor %}body.dark-mode .collapsible, body.dark-mode .content { background-color: {{ darkAccentColor or '#2d3a5e' }}; border-color: {{ darkAccentBorderColor or darkAccentColor or '#2d3a5e' }}; }{% endif %}
    {% if darkColor %}body.dark-mode { background-color: {{ darkColor }}; }{% endif %}
  </style>{% endif %}
</head>
<body>
  <h2>{{ title }}</h2>
  <button class="copyButton" onclick="copyLink()" aria-label="Kopiera länk till sida">Kopiera länk</button>
  <br><br>

  {% if uppsattning %}
    {% set _prefix = page.url | replace("/", "") %}
    {% for u in uppsattning %}
      {% set _sectionId = u.id | replace(_prefix ~ "-", "") | replace("-", "_") %}
      <br>
      <div class="uppsattning-header">
        <h2 class="uppsattning-heading" id="{{ _sectionId }}">{{ u.label }}</h2>
        <button class="uppsattning-link-btn" onclick="copyUppLink(this, '{{ _sectionId }}')" aria-label="Kopiera länk till {{ u.label }}"><img src="/assets/images/spex-copy-link-button.png" class="song-link-icon" alt=""></button>
      </div>
      <br>
      {% set groupSongs = collections.songs | songsForSpex(u.id) %}
      {% for song in groupSongs %}{{ song | renderSong | safe }}{% endfor %}
      <br>
    {% endfor %}
  {% elif spex %}
    {% set pageSongs = collections.songs | songsForSpex(spex) %}
    {% for song in pageSongs %}{{ song | renderSong | safe }}{% endfor %}
  {% else %}
    {{ content | safe }}
  {% endif %}

  <script>
    // Collapsible song sections — find .content inside the same .song-block
    var coll = document.getElementsByClassName("collapsible");
    for (var i = 0; i < coll.length; i++) {
      coll[i].addEventListener("click", function () {
        this.classList.toggle("active");
        var block = this.closest(".song-block");
        var contentDiv = block ? block.querySelector(".content") : this.nextElementSibling;
        if (contentDiv.style.maxHeight) {
          contentDiv.style.maxHeight = null;
        } else {
          contentDiv.style.maxHeight = contentDiv.scrollHeight + "px";
        }
      });
    }

    // Copy a direct anchor link to an uppsättning section
    function copyUppLink(btn, id) {
      var url = location.href.split("#")[0] + "#" + id;
      var img = btn.querySelector("img");
      function feedback() {
        if (img) {
          img.src = "/assets/images/spex-copy-link-feedback.png";
          setTimeout(function () { img.src = "/assets/images/spex-copy-link-button.png"; }, 1500);
        }
      }
      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(feedback).catch(function () { fallbackCopy(url); feedback(); });
      } else {
        fallbackCopy(url); feedback();
      }
    }

    // Copy a direct anchor link to a specific song
    function copySongLink(id) {
      var url = location.href.split("#")[0] + "#" + id;
      var songBtn = document.getElementById(id);
      var linkBtn = songBtn ? songBtn.nextElementSibling : null;
      var img = linkBtn ? linkBtn.querySelector("img") : null;

      function feedback() {
        if (img) {
          img.src = "/assets/images/spex-copy-link-feedback.png";
          setTimeout(function () { img.src = "/assets/images/spex-copy-link-button.png"; }, 1500);
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(feedback).catch(function () {
          fallbackCopy(url); feedback();
        });
      } else {
        fallbackCopy(url); feedback();
      }
    }

    function fallbackCopy(text) {
      var ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch (e) {}
      document.body.removeChild(ta);
    }

    // Open and scroll to a song or production section when the page loads with a hash
    document.addEventListener("DOMContentLoaded", function () {
      var hash = location.hash;
      if (hash && hash.length > 1) {
        var el = document.getElementById(hash.slice(1));
        if (!el) return;
        setTimeout(function () {
          el.scrollIntoView({ behavior: "smooth", block: "start" });
          if (el.classList.contains("collapsible")) {
            el.style.backgroundColor = "#ffd54f";
            setTimeout(function () { el.style.backgroundColor = ""; }, 2000);
            el.click();
          }
        }, 100);
      }
    });
  </script>
</body>

<!-- Footer -->
<script src="/scripts/footer.js" defer></script>
<div id="footer-container"></div>

</html>
