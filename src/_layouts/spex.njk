<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <title>{{ title }} - Bajbeln</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/style.css">
  <link rel="icon" type="image/png" href="/assets/images/logga.png">
  <link rel="manifest" href="/manifest.json">
  <script src="/scripts/songIndexCache.js" defer></script>
  <script src="/scripts/searchscript.js" defer></script>
  <script src="/scripts/pagescript.js" defer></script>
  <script src="/scripts/settings.js" defer></script>
  {% if color or accentColor or accentBorderColor %}<style>
    {% if color %}body { background-color: {{ color }}; }{% endif %}
    {% if accentColor %}.collapsible, .content { background-color: {{ accentColor }}; }{% endif %}
    {% if accentBorderColor %}.collapsible, .content { border-color: {{ accentBorderColor }}; }{% endif %}
  </style>{% endif %}
</head>
<body>
  <h2>{{ title }}</h2>
  <button class="copyButton" onclick="copyLink()" aria-label="Kopiera länk till sida">Kopiera länk</button>
  <br><br>

  {% set pageSongs = collections.songs | songsForSpex(spex) %}
  {% if pageSongs.length %}
    {% for song in pageSongs %}{{ song | renderSong | safe }}{% endfor %}
  {% else %}
    {{ content | safe }}
  {% endif %}

  <script>
    // Collapsible song sections — find .content inside the same .song-block
    var coll = document.getElementsByClassName("collapsible");
    for (var i = 0; i < coll.length; i++) {
      coll[i].addEventListener("click", function () {
        this.classList.toggle("active");
        var block = this.closest(".song-block");
        var contentDiv = block ? block.querySelector(".content") : this.nextElementSibling;
        if (contentDiv.style.maxHeight) {
          contentDiv.style.maxHeight = null;
        } else {
          contentDiv.style.maxHeight = contentDiv.scrollHeight + "px";
        }
      });
    }

    // Copy a direct anchor link to a specific song
    function copySongLink(id) {
      var url = location.href.split("#")[0] + "#" + id;
      var songBtn = document.getElementById(id);
      var linkBtn = songBtn ? songBtn.nextElementSibling : null;

      function feedback() {
        if (linkBtn) {
          var orig = linkBtn.textContent;
          linkBtn.textContent = "✓";
          setTimeout(function () { linkBtn.textContent = orig; }, 1500);
        }
      }

      if (navigator.clipboard && navigator.clipboard.writeText) {
        navigator.clipboard.writeText(url).then(feedback).catch(function () {
          fallbackCopy(url); feedback();
        });
      } else {
        fallbackCopy(url); feedback();
      }
    }

    function fallbackCopy(text) {
      var ta = document.createElement("textarea");
      ta.value = text;
      document.body.appendChild(ta);
      ta.select();
      try { document.execCommand("copy"); } catch (e) {}
      document.body.removeChild(ta);
    }

    // Open and scroll to a song when the page loads with a #song-* hash
    document.addEventListener("DOMContentLoaded", function () {
      var hash = location.hash;
      if (hash && hash.length > 1) {
        var btn = document.getElementById(hash.slice(1));
        if (btn && btn.classList.contains("collapsible")) {
          setTimeout(function () {
            btn.scrollIntoView({ behavior: "smooth", block: "start" });
            btn.style.backgroundColor = "#ffd54f";
            setTimeout(function () { btn.style.backgroundColor = ""; }, 2000);
            btn.click();
          }, 100);
        }
      }
    });
  </script>
</body>

<!-- Footer -->
<script src="/scripts/footer.js" defer></script>
<div id="footer-container"></div>

</html>
